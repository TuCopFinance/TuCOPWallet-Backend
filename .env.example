# Port the HTTP server binds to. Railway injects this automatically in prod.
# OPTIONAL (default: 8080).
PORT=8080

# ---------------------------------------------------------------------------
# Core infra
# ---------------------------------------------------------------------------

# Postgres connection string used by the transactions + Neeru indexers and
# the persistent WRI rate-limit fallback. Without it, indexers no-op and
# routes that depend on them return 503.
# OPTIONAL (REQUIRED if INDEXER_ENABLED=true or NEERU_INDEXER_ENABLED=true).
DATABASE_URL=

# Override pg pool max client count. Defaults to 20 (node-postgres default
# is 10, which can starve under indexer + concurrent HTTP load).
# OPTIONAL (default: 20).
PG_POOL_MAX=

# Override pg pool connection-acquisition timeout in milliseconds. When the
# pool is saturated, request fails fast (-> 503) instead of hanging.
# OPTIONAL (default: 5000).
PG_POOL_CONNECTION_TIMEOUT_MS=

# Override pg pool idle-client timeout in milliseconds.
# OPTIONAL (default: 30000).
PG_POOL_IDLE_TIMEOUT_MS=

# Redis connection string for cache (swap quote, prices, blockscout proxy)
# and the WRI per-address rate-limit slot store. Set to the literal string
# "disabled" to keep the var present but skip Redis entirely.
# OPTIONAL (default: caching disabled; WRI rate limit falls back to in-process
# Map - per-instance only, not safe for >1 replica).
REDIS_URL=

# Override the default Celo RPC URL used by the transactions indexer + WRI
# relay public client. The Neeru indexer has its own primary-then-fallback
# chain that uses this as the Forno entry.
# OPTIONAL (default: https://forno.celo.org).
FORNO_URL=

# ---------------------------------------------------------------------------
# Upstream providers
# ---------------------------------------------------------------------------

# Etherscan V2 unified API key. Server exits at boot if unset.
# REQUIRED.
ETHERSCAN_API_KEY=

# CoinMarketCap Pro API key. Required by /api/prices/xaut.
# OPTIONAL (REQUIRED for /api/prices/xaut; route returns 502 without it).
COINMARKETCAP_API_KEY=

# Blockscout API key. Injected as the `apikey` query param when proxying
# Blockscout V2 endpoints. Some Blockscout instances accept unauth'd reads,
# in which case this can stay empty.
# OPTIONAL (default: no apikey appended).
BLOCKSCOUT_API_KEY=

# Override the Blockscout base URL. Must use https:// AND the hostname must
# appear in the host allowlist in src/server.ts (default: celo.blockscout.com).
# Server exits at boot if either check fails.
# OPTIONAL (default: https://celo.blockscout.com).
BLOCKSCOUT_BASE_URL=

# Comma-separated extra hostnames allowed for BLOCKSCOUT_BASE_URL. Use when
# adding a new chain whose Blockscout instance is on a different domain.
# OPTIONAL (default: empty; only the built-in defaults in src/server.ts apply).
BLOCKSCOUT_ALLOWED_HOSTS=

# Squid Router integrator ID. Sent as x-integrator-id so swap volume
# attribution lands on TuCop.
# OPTIONAL (REQUIRED for /api/swap/quote; route returns 503 without it).
SQUID_INTEGRATOR_ID=

# ---------------------------------------------------------------------------
# WRI (EIP-7702 delegate relay)
# ---------------------------------------------------------------------------

# 32-byte hex private key (with 0x prefix) of the relay hot wallet that pays
# gas for one-time EIP-7702 delegation setup. Provision via `cast wallet new`
# and fund with ~10 CELO. Backend logs the derived address at startup so the
# loaded key is easy to confirm.
# OPTIONAL (REQUIRED for /api/wri/delegate-relay; route returns 503 without).
WRI_RELAY_PK=

# Minimum relay balance in wei. Below this the route returns 503 instead of
# submitting a tx that might run the wallet dry.
# OPTIONAL (default: 500000000000000000 = 0.5 CELO).
WRI_RELAY_MIN_CELO_BALANCE=

# Gas cap (uint256) the relay will commit on a single delegation tx.
# OPTIONAL (default: 1000000).
WRI_RELAY_MAX_GAS=

# Per-IP rate limit on /api/wri/delegate-relay (requests per minute). Defense
# against address-spraying from a single source. Tunable; set to 0 to disable.
# OPTIONAL (default: 20).
WRI_RELAY_PER_IP_LIMIT=

# Global token-bucket on /api/wri/delegate-relay (requests per minute across
# ALL addresses + IPs). Defense in depth against distributed attacks. Requires
# Redis; fail-closed (returns 503) when Redis is unavailable. Set to 0 to
# disable (default in dev/test). Recommended >=60 in production.
# OPTIONAL (default: 60).
WRI_RELAY_GLOBAL_LIMIT=

# ---------------------------------------------------------------------------
# Transactions indexer (Celo blocks -> classified TokenTransaction feed)
# ---------------------------------------------------------------------------

# Set to "true" to enable the transactions indexer worker at boot. Requires
# DATABASE_URL to be set; the indexer is a no-op otherwise.
# OPTIONAL (default: false / disabled).
INDEXER_ENABLED=

# ---------------------------------------------------------------------------
# Neeru indexer (partner contract event ingestion)
# ---------------------------------------------------------------------------

# Set to "true" to enable the Neeru indexer worker at boot. Requires
# DATABASE_URL + all NEERU_* vars below.
# OPTIONAL (default: false / disabled).
NEERU_INDEXER_ENABLED=

# Worker tick interval in milliseconds.
# OPTIONAL (default: 30000).
NEERU_INDEXER_INTERVAL_MS=

# Block number to start indexing from on first deploy. Must match the
# contract's deployment block to capture all historical events.
# OPTIONAL (REQUIRED if NEERU_INDEXER_ENABLED=true; throws at boot otherwise).
NEERU_INDEXER_GENESIS_BLOCK=

# Partner contract address. 0x + 40 hex.
# OPTIONAL (REQUIRED if NEERU_INDEXER_ENABLED=true; throws at boot otherwise).
NEERU_CONTRACT_ADDRESS=

# Four event topic0 hashes the indexer watches. Each is 0x + 64 hex.
# OPTIONAL (REQUIRED if NEERU_INDEXER_ENABLED=true; throws at boot otherwise).
NEERU_EVENT_A_TOPIC0=
NEERU_EVENT_B_TOPIC0=
NEERU_EVENT_C_TOPIC0=
NEERU_EVENT_D_TOPIC0=

# ---------------------------------------------------------------------------
# Neeru hooks-api / wallet surfaces
# ---------------------------------------------------------------------------

# Deposit-token address (the ERC20 the user deposits into Neeru tranches).
# Without it, the Neeru side of every hooks-api endpoint becomes a no-op
# (Allbridge results still flow through).
# OPTIONAL (REQUIRED for the Neeru slice of /hooks-api/* and /api/earn/neeru/*).
NEERU_DEPOSIT_TOKEN_ADDRESS=

# Template for tranche icon URLs. Use {N} as the tranche-id placeholder
# (0..3). Empty when unset.
# OPTIONAL (default: empty string).
NEERU_TRANCHE_IMAGE_URL_TEMPLATE=

# Surface link the wallet shows under "manage your position".
# OPTIONAL (default: empty string).
NEERU_MANAGE_URL=

# Surface link the wallet shows under "terms".
# OPTIONAL (default: empty string).
NEERU_TERMS_URL=

# ISO 8601 timestamp the partner contract was deployed. Surfaced in
# dataProps.contractCreatedAt.
# OPTIONAL (default: null).
NEERU_CONTRACT_CREATED_AT_ISO=
