{
  "name": "tucopwallet-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend services for TuCopWallet (Etherscan proxy and future microservices)",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && node -e \"const f=require('fs'); f.cpSync('src/db/migrations','dist/db/migrations',{recursive:true}); f.cpSync('public','dist/public',{recursive:true})\"",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3",
    "viem": "^2.53.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.17.10",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^8.57.1",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "resolutions": {
    "ws": "^8.21.0"
  }
}
